{
  "name": "seo-geo-auditor",
  "private": true,
  "version": "1.0.0",
  "description": "SEO & GEO Auditor — single-command dev server",
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "postinstall": "npm run install:frontend",
    "build:frontend": "npm run build --prefix frontend",
    "dev:frontend": "npm run build --prefix frontend -- --watch",
    "dev:backend": "bash scripts/start-backend.sh",
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "npm run build:frontend && bash scripts/start-backend.sh --no-reload"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
